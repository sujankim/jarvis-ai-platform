# ═══════════════════════════════════════════════════
# JARVIS AI PLATFORM — Environment Variables
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values in .env
# 3. NEVER commit .env to Git
# ═══════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────

# JWT Secret (generate with: openssl rand -base64 32)
# MUST be at least 32 characters
JARVIS_JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_SECRET

# Database
DATABASE_URL=r2dbc:postgresql://localhost:5432/jarvis
DATABASE_USERNAME=postgresql
DATABASE_PASSWORD=postgres

# Flyway uses JDBC (separate from R2DBC)
FLYWAY_URL=jdbc:postgresql://localhost:5432/jarvis

# ── OPTIONAL ──────────────────────────────────────

# Ollama (defaults shown — change if different)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Gemini API Key (for cloud fallback)
# Get free key at: https://aistudio.google.com/
# Leave empty to use Ollama only
GEMINI_API_KEY=

# Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Tool Engine (Phase 4) ──────────────────────────

# OpenWeatherMap — get free key at openweathermap.org/api
# 1000 calls/day on free tier
# Leave empty to disable weather tool
OPENWEATHER_API_KEY=

# Web search uses DuckDuckGo — no key needed

# ── Voice Assistant (Phase 5) ──────────────────────

# Option 1: Groq API (recommended — free + easy)
# Get free key at: console.groq.com
# Free tier: 6000 Whisper requests/day
GROQ_API_KEY=

# Option 2: Local whisper.cpp server
# Setup: github.com/ggerganov/whisper.cpp#http-server
# Then set in application.yml:
# jarvis.voice.whisper.base-url=http://localhost:8178
# jarvis.voice.whisper.api-key=not-needed

# ── DOCKER COMPOSE ─────────────────────────────────
# Used by docker-compose.yml
POSTGRES_PASSWORD=jarvis